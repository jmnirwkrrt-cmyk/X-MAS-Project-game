script_execute(global_variables);
script_execute(aircrafts);
if (!file_exists("xmas_settings.ini"))
{
	if (os_get_language() == "ru") script_execute(text_ru);
	else script_execute(text_eng);
}
else
{
	ini_open("xmas_settings.ini");
	var lang = ini_read_string("settings", "language", "eng");
	if (lang == "ru") script_execute(text_ru);
	else script_execute(text_eng);
	ini_close();
}
script_execute(global_variables);
script_execute(aircrafts);
script_execute(planes_and_infantry);
script_execute(script_technologies);
script_execute(onmap_buildings);
script_execute(ufopedia);
script_execute(onmap_buildings);
script_execute(sprite_load);
//script_execute(test_squads);
if (file_exists("xmas_settings.ini"))
{
	ini_open("xmas_settings.ini");
	global.musicvolume = ini_read_real("settings", "music_volume", 1.0);
	global.soundvolume = ini_read_real("settings", "sound_volume", 1.0);
	global.intros = "1" == ini_read_string("settings", "show_intro", "1");
	global.operatives_can_die = "1" == ini_read_string("settings", "operatives_can_die", "1");
	global.current_diff_mn = ini_read_real("settings", "difficult", global.current_diff_mn);
	global.save_number = ini_read_real("save", "save_number", global.save_number);
	global.autosave = "1" == ini_read_string("save", "autosave", "1");
	global.is_minigame_unlocked = "1" == ini_read_string("save", "is_minigame_unlocked", "1");
	global.skip_intro = "1" == ini_read_string("save", "skip_intro", "0");
	global.wait_if_target = "1" == ini_read_string("settings", "wait_if_target", "1");
	ini_close();
}
else
{
	ini_open("xmas_settings.ini");
	if (global.txt1 == "Гранаты") ini_write_string("settings", "language", "ru");
	else ini_write_string("settings", "language", "eng");
	ini_write_real("settings", "music_volume", global.musicvolume);
	ini_write_real("settings", "sound_volume", global.soundvolume);
	ini_write_string("settings", "show_intro", string(global.intros));
	ini_write_string("settings", "operatives_can_die", string(global.operatives_can_die));
	ini_write_string("settings", "wait_if_target", string(global.wait_if_target));
	ini_write_real("settings", "difficult", global.current_diff_mn);
	ini_write_real("save", "save_number", global.save_number);
	ini_write_string("save", "autosave", string(global.autosave));
	ini_write_string("save", "is_minigame_unlocked", string(global.is_minigame_unlocked));
	ini_write_string("save", "skip_intro", string(global.skip_intro));
	ini_close();
}

instance_create(1,1, music_commander);

if (!global.debug && !global.skip_intro)
{
	
	var _tex_array = texturegroup_get_textures( "Default");
	for (var i = 0; i < array_length(_tex_array); ++i;)
	{
	    texture_prefetch(_tex_array[i]);
	}
	_tex_array = texturegroup_get_textures( "XMAS_heroes");
	for (var i = 0; i < array_length(_tex_array); ++i;)
	{
	    texture_prefetch(_tex_array[i]);
	}
	_tex_array = texturegroup_get_textures( "EGG_heroes");
	for (var i = 0; i < array_length(_tex_array); ++i;)
	{
	    texture_prefetch(_tex_array[i]);
	}
	_tex_array = texturegroup_get_textures( "Planes");
	for (var i = 0; i < array_length(_tex_array); ++i;)
	{
	    texture_prefetch(_tex_array[i]);
	}
	_tex_array = texturegroup_get_textures( "GUI");
	for (var i = 0; i < array_length(_tex_array); ++i;)
	{
	    texture_prefetch(_tex_array[i]);
	}
	_tex_array = texturegroup_get_textures( "Effects");
	for (var i = 0; i < array_length(_tex_array); ++i;)
	{
	    texture_prefetch(_tex_array[i]);
	}
	
}


room_goto_next();