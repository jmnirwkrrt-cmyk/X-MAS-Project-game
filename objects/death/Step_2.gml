if (index = "snowmanak" or index = "snowmanrifle" or index = "snowmanlaser") { index = "snowman"; }

if (image_index = 32 and (index = "sonic" or index = "knuckles" or index = "pawn")) {image_index = 32; image_speed = 0;}
if (image_index = 40 and index = "snowman") {image_index = 40; image_speed = 0;}
if (image_index = 29 and (index = "shadow" or index = "tails")) {image_index = 29; image_speed = 0;}
if (image_index = 34 and index = "silver") {image_index = 34; image_speed = 0;}
if (image_index = 39 and (index = "rouge" or index = "metalson")) {image_index = 39; image_speed = 0;}
if (image_index = 45 and (index = "amy")) {image_index = 45; image_speed = 0;}

