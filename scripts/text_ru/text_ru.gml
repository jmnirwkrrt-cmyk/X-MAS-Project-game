	global.txt348 = "Вражеский транспорт активно десантирует боевых роботов с целью уничтожить одно из ключевых поселений Деда Мороза. Силы обороны города активно ведут бои, но не смогут выстоять в одиночку. Помогите продержаться армии Деда Мороза до прихода подкреплений#Сдерживайте врага до истечения указанного времени, в случае, если противник окажется слишком силён - запросите эвакуацию, но учтите, что в этом случае поселение будет уничтожено";
	global.txt349 = "НАЗЕМНЫЙ БОЙ: ЭКСТРАКЦИЯ ИЗУМРУДА";
	global.txt350 = "В этом районе было обнаружено излучение характерное для присутствия хаос-изумруда. Найдите изумруд, доставьте его на корабль и эвакуируйтесь, но не медлите, так как противник уже знает о вашем присутствии здесь#Найдите изумруд и доставьте его на корабль, в случае, если противник окажется слишком силён - запросите эвакуацию";
	global.txt351 = "НАЗЕМНЫЙ БОЙ: ШТУРМ АВАНПОСТА";
	global.txt352 = "В этом районе был обнаружен вражеский аванпост, угрожающий союзным силам и подрывающий деятельность проекта X-MAS. Проникните на базу и зачистите её от сил противника, но будьте осторожны, база серьёзно защищена и не перестаёт производить роботов, которые так и будут нападать на вас, пока вы не уничтожите все подъемники из производственного модуля#Уничтожьте все вражеские силы и лифты, в случае, если противник окажется слишком силён - запросите эвакуацию";
	global.txt353 = "НАЗЕМНЫЙ БОЙ: ОБОРОНА БАЗЫ";
	global.txt354 = "База проекта X-MAS была скомпрометирована и подверглась наземному нападению высаженным десантом, чей транспорт силам ПВО не удалось вовремя сбить. Сдерживайте натиск до прибытия подкрепления и не вздумайте отступать: поражение будет означать конец проекта X-MAS#Сдерживайте вражеские силы до истечения указанного времени";
