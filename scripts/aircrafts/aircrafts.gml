	global.eggplanedata[7, 4] = -1; // ячейка оружия, 0 = доступна, -1 = недоступна
	global.eggplanedata[7, 5] = -1; // макс. топливо
	global.eggplanedata[7, 6] = 1000; // макс. скорость
	global.eggplanedata[7, 7] = 1500; // скорость форсажа
	global.eggplanedata[7, 8] = 1; // скорость поворота
	global.eggplanedata[7, 9] = 0; // способность к уклонению, 0 - нет, 1 - есть
	global.eggplanedata[7, 10] = 1; // есть излучатель ПВО или нет, 0 - нет, 1 - есть
	global.eggplanedata[7, 11] = 1; // есть излучатель ПРО или нет, 0 - нет, 1 - есть
	global.eggplanedata[7, 12] = 100; // место для десанта
	global.eggplanedata[7, 13] = 0; // место для груза
	global.eggplanedata[7, 14] = 100; // дальность РЛС
	global.eggplanedata[7, 15] = 0.5; // ускорение
	global.eggplanedata[7, 16] = -1; // индекс в items
	global.eggplanedata[0, 0]++;




}
